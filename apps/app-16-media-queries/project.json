{
    "name": "app-16-media-queries",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "prefix": "app",
    "sourceRoot": "apps/app-16-media-queries/src",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@angular-devkit/build-angular:browser",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/apps/app-16-media-queries",
                "index": "apps/app-16-media-queries/src/index.html",
                "main": "apps/app-16-media-queries/src/main.ts",
                "polyfills": [],
                "tsConfig": "apps/app-16-media-queries/tsconfig.app.json",
                "assets": [
                    {
                        "glob": "**/*",
                        "input": "apps/app-16-media-queries/public"
                    }
                ],
                "styles": ["apps/app-16-media-queries/src/styles.css"],
                "scripts": []
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "500kb",
                            "maximumError": "1mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "2kb",
                            "maximumError": "4kb"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "buildOptimizer": false,
                    "optimization": false,
                    "vendorChunk": true,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "namedChunks": true
                }
            },
            "defaultConfiguration": "production"
        },
        "serve": {
            "executor": "@angular-devkit/build-angular:dev-server",
            "configurations": {
                "production": {
                    "buildTarget": "app-16-media-queries:build:production"
                },
                "development": {
                    "buildTarget": "app-16-media-queries:build:development"
                }
            },
            "defaultConfiguration": "development",
            "continuous": true
        },
        "extract-i18n": {
            "executor": "@angular-devkit/build-angular:extract-i18n",
            "options": {
                "buildTarget": "app-16-media-queries:build"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "apps/app-16-media-queries/jest.config.ts"
            }
        },
        "serve-static": {
            "executor": "@nx/web:file-server",
            "options": {
                "buildTarget": "app-16-media-queries:build",
                "spa": true
            }
        }
    }
}
